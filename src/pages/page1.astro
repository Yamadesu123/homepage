---
// src/pages/live.astro
import Layout from '../layouts/Layout.astro';

// SNS情報のリスト（--- の内側に移動しました）
const snsLinks = [
  { name: 'X (Twitter)', url: 'https://x.com/reportdasou', icon: 'fa-brands fa-x-twitter', color: '#000000' },
  { name: 'Instagram', url: 'https://instagram.com/yamap_dayon', icon: 'fa-brands fa-instagram', color: '#E4405F' },
  { name: 'Bluesky', url: 'https://bsky.app/profile/yamap-dayou.bsky.social', icon: 'svg-bluesky', color: '#0085ff' },
  { name: 'note', url: 'https://note.com/reportdasou/portal', icon: 'fa-solid fa-file-lines', color: '#2cb696' },
  { name: 'Eventernote', url: 'https://www.eventernote.com/users/YamaP_desu', icon: 'fa-solid fa-calendar-days', color: '#005bac' },
];
---
<body>
<header class="visual-header">
  <div class="header-overlay">
    <h1 class="header-visual-title">YamaP's Archive</h1>
  </div>
</header>

<Layout title="Live History & Reports - YamaP">
  <main class="container">
    <section class="white-block info-section">
      <div class="balloon-title">Live Reports (note)</div>
      <div class="block-content">
        <p class="intro-text">詳しい感想は note に書いています。</p>
        
        <div class="note-link-grid">
           <a href="https://note.com/reportdasou/n/nbe586cd7beeb" target="_blank" class="blog-item">
        <span class="blog-date">2026.03.06</span>
        <div class="blog-body">
          <span class="blog-category">Live Report</span>
          <p class="blog-title">MyGO!!!!!×Ave Mujicaツーマンライブ ｢"moment / memory"｣ ライブレポート</p>
        </div>
      </a>

      <!-- 記事2 -->
      <a href="https://note.com/reportdasou/n/n5dea493a9c57" target="_blank" class="blog-item">
        <span class="blog-date">2026.03.03</span>
        <div class="blog-body">
          <span class="blog-category">Live Report</span>
          <p class="blog-title">Roselia ASIA TOUR ｢neuweltfahrt｣ 東京公演 -final- DAY2 ライブレポート</p>
        </div>
      </a>
        </div>
      </div>
    </section>

    <section id='upcoming events' class="white-block info-section">
  <div class="balloon-title">イベント参戦予定</div>
  <div class="block-content">
    <ul class="event-history-list">
      <li>いのりまち 町民集会2026 第2部</li>
      <li>東山奈央 東山奈央プロジェクト2026キックオフイベント~いくぜぶどうかん!!~</li>
      <li>Poppin'Party×Roselia 合同ライブ「DREAMS GO ON」</li>
      <li>大橋彩香ワンマンライブ(仮)</li>
      <li>RAISE A SUILEN LIVE 2026「Boot IGNITION」</li>
      <li>MyGO!!!!! 9th LIVE Day2</li>
    </ul>
  </div>
</section>

  </main>

    <footer class="site-footer">
  <div class="sns-icons">
    {snsLinks.map(sns => (
      <a href={sns.url} target="_blank" rel="noopener noreferrer" aria-label={sns.name} class="sns-link">
        {sns.icon === 'svg-bluesky' ? (
          <svg viewBox="0 0 512 512" style={`fill: ${sns.color}; width: 1.8rem; height: 1.8rem; vertical-align: middle;`}>
            <path d="M111.8 62.2C170.2 105.9 233 194.7 256 242.4c23-47.6 85.8-136.4 144.2-180.2c42.1-31.6 110.3-56 110.3 21.8c0 15.5-8.9 130.5-14.1 149.2C478.1 298 412 314.6 353.1 304.5c102.9 17.5 129.1 75.5 72.5 140.6c-83 95.1-159.4-15.8-169.6-30.2c-10.2 14.4-86.6 125.3-169.6 30.2c-56.7-65.1-30.4-123.1 72.5-140.6C99.9 314.6 33.8 298 15.7 233.1C10.5 214.4 1.6 99.5 1.6 84c0-77.8 68.2-53.4 110.2-21.8z"/>
          </svg>
        ) : (
          <i class={sns.icon} style={`color: ${sns.color}`}></i>
        )}
      </a>
    ))}
  </div>
  <p>
    Built with 
    <a href="https://astro.build" target="_blank" rel="noopener" class="astro-link">
      Astro
    </a>
  </p>
  <p>&copy; 2026 YamaP</p>
</footer>

</Layout>
</body>
    
<style>
  .sns-icons {
    display: flex;
    justify-content: center;
    gap: 25px;
    margin-top: 20px;
    font-size: 1.8rem;
  }

  .sns-icons a {
    transition: transform 0.2s;
  }

  .sns-icons a:hover {
    transform: scale(1.2);
  }
</style>